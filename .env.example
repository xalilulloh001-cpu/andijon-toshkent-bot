# ===== TELEGRAM =====
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
ADMIN_IDS=123456789,987654321
SUPPORT_CHAT_ID=-1001234567890

# ===== DATABASE =====
DATABASE_URL=postgresql://postgres:password@postgres:5432/anditaxi
DB_PASSWORD=your_secure_password

# ===== REDIS =====
REDIS_URL=redis://redis:6379

# ===== SMS SERVICE =====
SMS_API_URL=https://api.esk.uz/api/messages/sms/send
SMS_API_KEY=your_sms_api_key_here
SMS_SENDER_NAME=AndTaxi

# ===== WEBSOCKET =====
WEBSOCKET_URL=wss://yourdomain.uz

# ===== FEATURES =====
FEATURE_PAYMENT_SYSTEM=false
FEATURE_SMS_VERIFICATION=true
FEATURE_PIN_VERIFICATION=true
FEATURE_REAL_TIME_TRACKING=true
FEATURE_RATING_MODERATION=true
FEATURE_OFFLINE_DETECTION=true

# ===== MATCHING SETTINGS =====
MATCHING_RADIUS_KM=15
MAX_PASSENGERS_PER_GROUP=4
OFFER_TIMEOUT_MINUTES=5

# ===== BAN SETTINGS =====
FALSE_CANCEL_THRESHOLD=3
FALSE_CANCEL_BAN_HOURS=24
SOS_ABUSE_THRESHOLD=2
SOS_ABUSE_BAN_HOURS=48
LOW_RATING_THRESHOLD=3.0
LOW_RATING_MIN_COUNT=5

# ===== SMS RATE LIMITING =====
SMS_RATE_LIMIT_PER_HOUR=3
SMS_RATE_LIMIT_WINDOW_MINUTES=60

# ===== SECURITY =====
PIN_LENGTH=4
PIN_FAILED_ATTEMPTS_LOCK=3
PIN_LOCK_DURATION_MINUTES=15

# ===== LOCATION BOUNDS =====
ANDIJON_LAT=40.7281
ANDIJON_LNG=72.3391
ANDIJON_RADIUS_KM=50

TASHKENT_LAT=41.2995
TASHKENT_LNG=69.2401
TASHKENT_RADIUS_KM=50

# ===== DRIVER OFFLINE DETECTION =====
DRIVER_HEARTBEAT_TIMEOUT_SECONDS=300
OFFLINE_CHECK_INTERVAL_SECONDS=30

# ===== LOGGING =====
LOG_LEVEL=INFO
